<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MorpionMaui.MainPage"
             BackgroundColor="#1a1a2e"
             Title="Morpion">

    <VerticalStackLayout Padding="24,40,24,24" Spacing="16" VerticalOptions="Center">

        <Label Text="MORPION"
               FontSize="36"
               FontAttributes="Bold"
               TextColor="#e94560"
               HorizontalOptions="Center" />

        <Label Text="{Binding StatusText}"
               FontSize="20"
               TextColor="White"
               HorizontalOptions="Center" />

        <Grid ColumnDefinitions="*,*,*"
              RowDefinitions="*,*,*"
              WidthRequest="300"
              HeightRequest="300"
              HorizontalOptions="Center">

            <!-- Ligne 0 -->
            <Button Grid.Row="0" Grid.Column="0"
                    Text="{Binding Cell00}"
                    FontSize="48" FontAttributes="Bold"
                    BackgroundColor="#16213e" TextColor="White"
                    CornerRadius="16" Margin="6"
                    Command="{Binding PlayCommand}" CommandParameter="0,0" />

            <Button Grid.Row="0" Grid.Column="1"
                    Text="{Binding Cell01}"
                    FontSize="48" FontAttributes="Bold"
                    BackgroundColor="#16213e" TextColor="White"
                    CornerRadius="16" Margin="6"
                    Command="{Binding PlayCommand}" CommandParameter="0,1" />

            <Button Grid.Row="0" Grid.Column="2"
                    Text="{Binding Cell02}"
                    FontSize="48" FontAttributes="Bold"
                    BackgroundColor="#16213e" TextColor="White"
                    CornerRadius="16" Margin="6"
                    Command="{Binding PlayCommand}" CommandParameter="0,2" />

            <!-- Ligne 1 -->
            <Button Grid.Row="1" Grid.Column="0"
                    Text="{Binding Cell10}"
                    FontSize="48" FontAttributes="Bold"
                    BackgroundColor="#16213e" TextColor="White"
                    CornerRadius="16" Margin="6"
                    Command="{Binding PlayCommand}" CommandParameter="1,0" />

            <Button Grid.Row="1" Grid.Column="1"
                    Text="{Binding Cell11}"
                    FontSize="48" FontAttributes="Bold"
                    BackgroundColor="#16213e" TextColor="White"
                    CornerRadius="16" Margin="6"
                    Command="{Binding PlayCommand}" CommandParameter="1,1" />

            <Button Grid.Row="1" Grid.Column="2"
                    Text="{Binding Cell12}"
                    FontSize="48" FontAttributes="Bold"
                    BackgroundColor="#16213e" TextColor="White"
                    CornerRadius="16" Margin="6"
                    Command="{Binding PlayCommand}" CommandParameter="1,2" />

            <!-- Ligne 2 -->
            <Button Grid.Row="2" Grid.Column="0"
                    Text="{Binding Cell20}"
                    FontSize="48" FontAttributes="Bold"
                    BackgroundColor="#16213e" TextColor="White"
                    CornerRadius="16" Margin="6"
                    Command="{Binding PlayCommand}" CommandParameter="2,0" />

            <Button Grid.Row="2" Grid.Column="1"
                    Text="{Binding Cell21}"
                    FontSize="48" FontAttributes="Bold"
                    BackgroundColor="#16213e" TextColor="White"
                    CornerRadius="16" Margin="6"
                    Command="{Binding PlayCommand}" CommandParameter="2,1" />

            <Button Grid.Row="2" Grid.Column="2"
                    Text="{Binding Cell22}"
                    FontSize="48" FontAttributes="Bold"
                    BackgroundColor="#16213e" TextColor="White"
                    CornerRadius="16" Margin="6"
                    Command="{Binding PlayCommand}" CommandParameter="2,2" />

        </Grid>

    </VerticalStackLayout>

</ContentPage>