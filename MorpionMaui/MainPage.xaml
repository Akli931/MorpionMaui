<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MorpionMaui.MainPage"
             BackgroundColor="#1a1a2e"
             Title="Morpion">

    <VerticalStackLayout Padding="24,40,24,24" Spacing="16" VerticalOptions="Center">

        <!-- Titre du jeu -->
        <Label x:Name="TitleLabel"
               Text="MORPION"
               FontSize="36"
               FontAttributes="Bold"
               TextColor="#e94560"
               HorizontalOptions="Center" />

        <!-- Indique à qui c'est le tour -->
        <Label x:Name="StatusLabel"
               Text="Tour du joueur X"
               FontSize="20"
               TextColor="White"
               HorizontalOptions="Center" />

        <!-- Grille 3x3 -->
        <Grid ColumnDefinitions="*,*,*"
              RowDefinitions="*,*,*"
              WidthRequest="300"
              HeightRequest="300"
              HorizontalOptions="Center">

            <!-- Ligne 0 -->
            <Button Grid.Row="0" Grid.Column="0" x:Name="Btn00" Text=""
                    FontSize="48" FontAttributes="Bold"
                    BackgroundColor="#16213e" TextColor="White"
                    CornerRadius="16" Margin="6"
                    Clicked="OnCellClicked" CommandParameter="0,0" />

            <Button Grid.Row="0" Grid.Column="1" x:Name="Btn01" Text=""
                    FontSize="48" FontAttributes="Bold"
                    BackgroundColor="#16213e" TextColor="White"
                    CornerRadius="16" Margin="6"
                    Clicked="OnCellClicked" CommandParameter="0,1" />

            <Button Grid.Row="0" Grid.Column="2" x:Name="Btn02" Text=""
                    FontSize="48" FontAttributes="Bold"
                    BackgroundColor="#16213e" TextColor="White"
                    CornerRadius="16" Margin="6"
                    Clicked="OnCellClicked" CommandParameter="0,2" />

            <!-- Ligne 1 -->
            <Button Grid.Row="1" Grid.Column="0" x:Name="Btn10" Text=""
                    FontSize="48" FontAttributes="Bold"
                    BackgroundColor="#16213e" TextColor="White"
                    CornerRadius="16" Margin="6"
                    Clicked="OnCellClicked" CommandParameter="1,0" />

            <Button Grid.Row="1" Grid.Column="1" x:Name="Btn11" Text=""
                    FontSize="48" FontAttributes="Bold"
                    BackgroundColor="#16213e" TextColor="White"
                    CornerRadius="16" Margin="6"
                    Clicked="OnCellClicked" CommandParameter="1,1" />

            <Button Grid.Row="1" Grid.Column="2" x:Name="Btn12" Text=""
                    FontSize="48" FontAttributes="Bold"
                    BackgroundColor="#16213e" TextColor="White"
                    CornerRadius="16" Margin="6"
                    Clicked="OnCellClicked" CommandParameter="1,2" />

            <!-- Ligne 2 -->
            <Button Grid.Row="2" Grid.Column="0" x:Name="Btn20" Text=""
                    FontSize="48" FontAttributes="Bold"
                    BackgroundColor="#16213e" TextColor="White"
                    CornerRadius="16" Margin="6"
                    Clicked="OnCellClicked" CommandParameter="2,0" />

            <Button Grid.Row="2" Grid.Column="1" x:Name="Btn21" Text=""
                    FontSize="48" FontAttributes="Bold"
                    BackgroundColor="#16213e" TextColor="White"
                    CornerRadius="16" Margin="6"
                    Clicked="OnCellClicked" CommandParameter="2,1" />

            <Button Grid.Row="2" Grid.Column="2" x:Name="Btn22" Text=""
                    FontSize="48" FontAttributes="Bold"
                    BackgroundColor="#16213e" TextColor="White"
                    CornerRadius="16" Margin="6"
                    Clicked="OnCellClicked" CommandParameter="2,2" />

        </Grid>

        <!-- Bouton pour recommencer une partie -->
        <Button x:Name="ResetBtn"
                Text="Nouvelle Partie"
                FontSize="18"
                FontAttributes="Bold"
                BackgroundColor="#e94560"
                TextColor="White"
                CornerRadius="12"
                HeightRequest="52"
                Margin="0,10,0,0"
                Clicked="OnResetClicked" />

    </VerticalStackLayout>

</ContentPage>
